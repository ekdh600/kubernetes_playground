# Dockerfile.ui — 플레이그라운드 UI 서버 이미지 빌드
#
# 결과 이미지 역할:
#   Nginx를 사용하여 정적 HTML/CSS/JS 파일을 서빙하고,
#   API 요청과 WebSocket 연결을 백엔드 API 서버로 역방향 프록시한다.
#
# nginx:alpine 선택 이유:
#   풀 Ubuntu Nginx 이미지 대비 ~95% 작은 크기 (~25MB).
#   정적 파일 서빙과 간단한 프록시에는 alpine이 충분하다.
#
# envsubst 지원:
#   nginx:alpine 이미지는 /etc/nginx/templates/ 디렉터리의 *.template 파일을
#   컨테이너 시작 시 envsubst로 자동 처리하여 /etc/nginx/conf.d/에 저장한다.
#   이를 통해 API_HOST 환경변수가 nginx.conf에 동적으로 주입된다.

FROM nginx:alpine

# nginx:alpine 기본 설정 파일 제거 (기본 "Welcome to nginx!" 페이지 비활성화)
RUN rm /etc/nginx/conf.d/default.conf

# nginx 설정 템플릿 복사:
# /etc/nginx/templates/default.conf.template → 시작 시 envsubst → /etc/nginx/conf.d/default.conf
# ${API_HOST} 변수가 K8s Deployment의 env에서 주입된다.
COPY nginx.conf.template /etc/nginx/templates/default.conf.template

# 정적 프론트엔드 파일을 nginx 기본 서빙 디렉터리에 복사한다.
# index.html (사용자 터미널 UI), admin.html (관리자 대시보드)가 포함된다.
COPY static/ /usr/share/nginx/html/

# HTTP 포트 노출 (K8s NodePort Service의 targetPort와 일치)
EXPOSE 80

# nginx를 포그라운드(daemon off)로 실행하여 컨테이너가 종료되지 않도록 한다.
CMD ["nginx", "-g", "daemon off;"]
